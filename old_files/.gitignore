# Global .gitignore for monorepo (Node.js, Next.js, Astro, etc.)

# Build output
dist/
.next/
out/
build/

# Astro generated types
.astro/

# Dependencies
node_modules/
.pnp
.pnp.js

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Environment variables
.env
.env*.local
.env.production

# macOS-specific files
.DS_Store

# Netlify/Vercel
.netlify/
.vercel/

# Database
**/*.sqlite
**/*.sqlite-journal

# TypeScript
*.tsbuildinfo

# Misc
*.pem
.idea/

# Ignore local IDE/editor folders
.vscode/

# Coverage
coverage/

# Ignore example env files only if not needed
# !.env.example